AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_MODEL=gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/neuro_assistant

# Secret key for signing JWT tokens — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-secret-key-here

# Local/dev convenience: when true, forgot-password returns the reset token in the API response.
# Keep this false outside local development and deliver the token by email instead.
PASSWORD_RESET_RETURN_TOKEN=false
